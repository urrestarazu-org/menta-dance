---
title: Relaciones de Datos por Módulo
---
erDiagram
    USERS ||--o{ USERS_ROLES : has
    ROLES ||--o{ USERS_ROLES : grants
    USERS ||--o{ REFRESH_TOKENS : owns

    COURSES ||--o{ MODULES : contains
    MODULES ||--o{ LESSONS : contains
    LESSONS ||--o{ LESSON_PROGRESS : tracks

    PHYSICAL_COURSES ||--o{ CLASS_SESSIONS : generates
    CLASS_SESSIONS ||--o{ CAPACITY_HOLD_SESSIONS : holds
    CAPACITY_HOLDS ||--o{ CAPACITY_HOLD_SESSIONS : contains
    CLASS_SESSIONS ||--o{ CAPACITY_ASSIGNMENTS : allocates
    CAPACITY_ASSIGNMENTS ||--o| ATTENDANCE : authorizes

    PHYSICAL_COURSE_PRICING ||--o{ PHYSICAL_COURSE_PRICING_REVISIONS : audits
    PHYSICAL_COURSE_PRICING ||--o{ PHYSICAL_PRICE_QUOTES : snapshots
    PHYSICAL_PRICE_QUOTES ||--o{ PHYSICAL_PURCHASES : originates
    PHYSICAL_PURCHASES ||--|| PHYSICAL_PAYMENTS : pays
    PHYSICAL_PAYMENTS ||--o{ PHYSICAL_PAYMENT_AUDITS : audits

    USERS {
        bigint id PK
        varchar email
        varchar status
    }
    ROLES {
        bigint id PK
        varchar name
    }
    USERS_ROLES {
        bigint user_id PK,FK
        bigint role_id PK,FK
    }
    REFRESH_TOKENS {
        bigint id PK
        bigint user_id FK
        datetime expires_at
    }

    COURSES {
        bigint id PK
        varchar title
        varchar status
    }
    MODULES {
        bigint id PK
        bigint course_id FK
    }
    LESSONS {
        bigint id PK
        bigint module_id FK
    }
    LESSON_PROGRESS {
        bigint id PK
        bigint lesson_id FK
        bigint user_id
    }

    PHYSICAL_COURSES {
        bigint id PK
        bigint professor_id
        varchar day_of_week
        time start_time
        time end_time
        int capacity
    }
    CLASS_SESSIONS {
        bigint id PK
        bigint course_id FK
        bigint professor_id
        datetime starts_at
        int capacity
        varchar status
    }
    CAPACITY_HOLDS {
        varchar id PK
        varchar quote_id
        bigint user_id
        varchar status
        datetime expires_at
    }
    CAPACITY_HOLD_SESSIONS {
        varchar hold_id PK,FK
        bigint session_id PK,FK
    }
    CAPACITY_ASSIGNMENTS {
        bigint id PK
        bigint payment_id
        varchar quote_id
        bigint user_id
        bigint session_id FK
        varchar assignment_type
    }
    ATTENDANCE {
        bigint id PK
        bigint assignment_id FK
        bigint user_id
        bigint session_id FK
        varchar qr_jti
        varchar status
        datetime checked_in_at
    }

    PHYSICAL_COURSE_PRICING {
        bigint course_id PK
        decimal monthly_price
        decimal individual_surcharge_percent
        bigint version
    }
    PHYSICAL_COURSE_PRICING_REVISIONS {
        bigint id PK
        bigint course_id
        bigint version
        decimal old_monthly_price
        decimal new_monthly_price
        decimal old_surcharge
        decimal new_surcharge
        bigint professor_id
        varchar reason
        datetime changed_at
    }
    PHYSICAL_PRICE_QUOTES {
        varchar id PK
        bigint course_id
        bigint professor_id
        varchar purchase_type
        bigint selected_session_id
        date coverage_start_date
        date coverage_end_exclusive
        int scheduled_session_count
        decimal monthly_price
        decimal effective_rounded
        decimal individual_surcharge_percent
        decimal individual_price
        decimal quoted_total
        bigint pricing_version
        json session_ids
        datetime expires_at
    }
    PHYSICAL_PURCHASES {
        bigint id PK
        bigint user_id
        varchar quote_id FK
        varchar capacity_hold_id
        varchar status
        varchar idempotency_key
    }
    PHYSICAL_PAYMENTS {
        bigint id PK
        bigint purchase_id FK
        decimal amount
        varchar payment_method
        varchar status
        varchar external_id
    }
    PHYSICAL_PAYMENT_AUDITS {
        bigint id PK
        bigint payment_id FK
        bigint purchase_id FK
        bigint actor_user_id
        varchar action
    }
    PAYMENT_WEBHOOK_INBOX {
        bigint id PK
        varchar provider
        varchar provider_event_id
        varchar status
        int attempts
        datetime next_attempt_at
    }


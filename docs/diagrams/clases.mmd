---
title: Diagrama de Clases del Proyecto (Modelo Conceptual Completo)
---
classDiagram
    direction TB

    %% ==========================================
    %% DOMINIO: MÓDULO AUTH & USER CORE
    %% ==========================================
    class User {
        +Long id
        +String firstName
        +String lastName
        +LocalDate birthday
        +String email
        +String password
        +String phoneNumber
        +LocalDateTime createdAt
        +LocalDateTime updatedAt
        +UserStatus status
        +String activationCode
        +LocalDateTime activationCodeExpiryDate
        +int failedActivationAttempts
        +int failedLoginAttempts
        +LocalDateTime lastFailedLoginDate
        +LocalDateTime accountLockedUntil
        +List~Role~ roles
        +List~PasswordResetToken~ passwordResetTokens
        +List~RefreshToken~ refreshTokens
    }

    class UserStatus {
        <<enumeration>>
        PENDIENTE
        ACTIVO
        INACTIVO
        BLOQUEADO
    }

    class Role {
        +Long id
        +RoleEnum name
        +List~User~ users
    }

    class RoleEnum {
        <<enumeration>>
        USER
        ADMIN
    }

    class PasswordResetToken {
        +Long id
        +String token
        +User user
        +LocalDateTime expiryDate
    }

    class RefreshToken {
        +Long id
        +User user
        +String tokenHash
        +String deviceInfo
        +String ipAddress
        +LocalDateTime expiresAt
        +LocalDateTime revokedAt
        +LocalDateTime createdAt
        +boolean isExpired()
        +boolean isRevoked()
        +boolean isValid()
        +void revoke()
    }

    %% ==========================================
    %% DOMINIO: MÓDULO BILLING & PAYMENTS
    %% ==========================================
    class PhysicalCoursePricing {
        +CourseId courseId
        +Money monthlyPrice
        +BigDecimal individualSurchargePercent
        +Currency currency
        +long version
    }

    class PricingRevision {
        +CourseId courseId
        +long version
        +Money oldMonthlyPrice
        +Money newMonthlyPrice
        +BigDecimal oldSurcharge
        +BigDecimal newSurcharge
        +ProfessorId professorId
        +String reason
        +Instant changedAt
    }

    class PriceQuote {
        +QuoteId id
        +CourseId courseId
        +ProfessorId professorId
        +PurchaseType purchaseType
        +SessionId selectedSessionId
        +LocalDate coverageStartDate
        +LocalDate coverageEndExclusive
        +int scheduledSessionCount
        +Money monthlyPrice
        +Money effectiveRounded
        +BigDecimal individualSurchargePercent
        +Money individualPrice
        +Money quotedTotal
        +Currency currency
        +long pricingVersion
        +List~SessionId~ sessionIds
        +Instant createdAt
        +Instant expiresAt
    }

    class Purchase {
        +Long id
        +UserId userId
        +QuoteId quoteId
        +PurchaseStatus status
        +HoldId capacityHoldId
        +String idempotencyKey
    }

    class Payment {
        +PaymentId id
        +PurchaseId purchaseId
        +PaymentMethod paymentMethod
        +PaymentStatus status
        +Money amount
        +String externalId
    }

    class PaymentStatus {
        <<enumeration>>
        PENDING
        COMPLETED
        FAILED
        REQUIRES_MANUAL_REVIEW
    }

    class PurchaseStatus {
        <<enumeration>>
        QUOTED
        PAYMENT_PENDING
        CAPACITY_ASSIGNED
        EXCEPTION
        CANCELLED
    }

    class PaymentMethod {
        <<enumeration>>
        MERCADO_PAGO
        BANK_TRANSFER
        CASH
    }

    class PurchaseType {
        <<enumeration>>
        MONTHLY
        INDIVIDUAL
    }

    %% ==========================================
    %% DOMINIO: MÓDULO VIRTUAL & ONLINE CONTENT
    %% ==========================================
    class Course {
        +Long id
        +String title
        +String subtitle
        +String description
        +String bodyText
        +Long idPrevCourse
        +Long idNextCourse
        +String imageUrl
        +String purchaseUrl
        +Video video
        +Set~Module~ modules
    }

    class Module {
        +Long id
        +String title
        +String description
        +Long prevModuleId
        +Long nextModuleId
        +Video video
        +Course course
        +Set~Lesson~ lessons
    }

    class Lesson {
        +Long id
        +String title
        +String description
        +boolean completed
        +Video video
        +Module module
        +List~LessonProgress~ progressList
    }

    class LessonProgress {
        +Long id
        +UserId userId
        +Lesson lesson
        +boolean completed
        +Integer progressPercent
        +Integer lastPositionSeconds
        +LocalDateTime completedAt
        +LocalDateTime createdAt
        +LocalDateTime updatedAt
        +void markAsCompleted()
    }

    class Video {
        +Long id
        +String title
        +String bunnyVideoId
        +String description
        +String duration
        +boolean isShort
    }

    %% ==========================================
    %% DOMINIO: MÓDULO PHYSICAL & PRESENCIAL
    %% ==========================================
    class PhysicalCourse {
        +Long id
        +String title
        +String subtitle
        +String description
        +DanceStyle danceStyle
        +DifficultyLevel difficultyLevel
        +Location location
        +ProfessorId professorId
        +String instructorBio
        +String instructorPhotoUrl
        +Integer maxCapacity
        +Integer durationMinutes
        +String imageUrl
        +Boolean active
        +Boolean published
        +LocalDateTime createdAt
        +LocalDateTime updatedAt
        +RecurrenceRule recurrence
        +List~ClassSession~ sessions
    }

    class Location {
        +Long id
        +String name
        +String address
        +String city
        +String neighborhood
        +String googleMapsUrl
        +Integer capacity
        +String description
        +String contactPhone
        +String contactEmail
        +Boolean active
        +LocalDateTime createdAt
        +LocalDateTime updatedAt
    }

    class RecurrenceRule {
        +DayOfWeek dayOfWeek
        +LocalTime startTime
        +LocalTime endTime
        +LocalDate validFrom
        +LocalDate validUntil
    }

    class ClassSession {
        +Long id
        +PhysicalCourse course
        +ProfessorId professorId
        +Instant startsAt
        +Instant endsAt
        +Integer capacity
        +SessionStatus status
        +String notes
        +String cancelledReason
        +String substituteInstructor
        +LocalDateTime createdAt
        +LocalDateTime updatedAt
        +List~CapacityAssignment~ assignments
    }

    class CapacityHold {
        +HoldId id
        +QuoteId quoteId
        +UserId userId
        +CapacityHoldStatus status
        +Instant expiresAt
        +List~SessionId~ sessionIds
    }

    class CapacityAssignment {
        +Long id
        +PaymentId paymentId
        +QuoteId quoteId
        +UserId userId
        +SessionId sessionId
        +PurchaseType assignmentType
        +Instant assignedAt
    }

    class Attendance {
        +Long id
        +CapacityAssignment assignment
        +UserId userId
        +SessionId sessionId
        +String qrJti
        +AttendanceStatus status
        +LocalDateTime checkInTime
        +LocalDateTime checkOutTime
        +String checkedInBy
        +String notes
        +LocalDateTime createdAt
        +LocalDateTime updatedAt
    }

    class DanceStyle {
        <<enumeration>>
        SALSA
        BACHATA
        TANGO
        URBANO
        CONTEMPORANEO
    }

    class DifficultyLevel {
        <<enumeration>>
        PRINCIPIANTE
        INTERMEDIO
        AVANZADO
    }

    class CapacityHoldStatus {
        <<enumeration>>
        ACTIVE
        CONVERTED
        EXPIRED
        RELEASED
    }

    class SessionStatus {
        <<enumeration>>
        SCHEDULED
        COMPLETED
        CANCELLED
        RESCHEDULED
    }

    class AttendanceStatus {
        <<enumeration>>
        PRESENT
        ABSENT
        LATE
        EXCUSED
    }

    %% ==========================================
    %% NOTIFICACIONES (GENERAL)
    %% ==========================================
    class Notification {
        +Long id
        +String message
        +String meetLink
        +LocalDateTime startTime
        +LocalDateTime endTime
        +LocalDateTime createdAt
    }

    %% ==========================================
    %% RELACIONES
    %% ==========================================
    
    %% Relaciones User Core (módulo Auth)
    User "*" -- "*" Role : has
    User "1" -- "*" PasswordResetToken : has
    User "1" -- "*" RefreshToken : has
    User -- UserStatus : uses
    Role -- RoleEnum : uses

    %% Relaciones de precios y pagos (módulo Billing)
    PhysicalCoursePricing "1" -- "*" PriceQuote : snapshots
    PhysicalCoursePricing "1" -- "*" PricingRevision : audits
    PriceQuote "1" -- "*" Purchase : originates
    Purchase "1" -- "1" Payment : pays
    PriceQuote -- PurchaseType : uses
    Purchase -- PurchaseStatus : uses
    Payment -- PaymentMethod : uses
    Payment -- PaymentStatus : uses

    %% Relaciones Contenido Online (módulo Virtual)
    Course "1" -- "*" Module : contains
    Module "1" -- "*" Lesson : contains
    Course "*" -- "0..1" Video : has intro
    Module "*" -- "0..1" Video : has intro
    Lesson "*" -- "0..1" Video : has content
    Lesson "1" -- "*" LessonProgress : has progress

    %% Relaciones Academia Presencial (módulo Physical)
    PhysicalCourse "*" -- "1" Location : located at
    PhysicalCourse "1" -- "1" RecurrenceRule : follows
    PhysicalCourse "1" -- "*" ClassSession : has sessions
    PhysicalCourse -- DanceStyle : uses
    PhysicalCourse -- DifficultyLevel : uses
    RecurrenceRule -- DayOfWeek : uses
    
    ClassSession "*" -- "1" PhysicalCourse : instantiates
    ClassSession -- SessionStatus : uses
    ClassSession "*" -- "*" CapacityHold : technical hold
    ClassSession "1" -- "*" CapacityAssignment : allocates
    ClassSession "1" -- "*" Attendance : registers
    CapacityHold -- CapacityHoldStatus : uses
    CapacityAssignment -- PurchaseType : uses
    Attendance "*" -- "1" ClassSession : in
    Attendance "1" -- "1" CapacityAssignment : authorizes
    Attendance -- AttendanceStatus : uses

    %% Referencias entre módulos (sin navegación ni imports directos)
    note for PhysicalCoursePricing "courseId referencia lógicamente a Physical; Billing conserva ownership del precio."
    note for PriceQuote "sessionIds y professorId son snapshots lógicos de Physical."
    note for Purchase "userId referencia a Auth; quoteId pertenece a Billing."
    note for LessonProgress "userId referencia lógicamente a Auth, sin importar User."
    note for CapacityAssignment "paymentId y quoteId referencian Billing mediante IDs, sin importar entidades."
    note for Attendance "userId es una referencia lógica, no una navegación a User."

    %% Notas de Arquitectura / Seguridad
    note for User "Usuario centralizado (módulo Auth). Activación por código. Control de bloqueos por login fallido."
    note for RefreshToken "JWT Refresh Token (módulo Auth) para rotación segura y persistencia de sesión."
    note for Payment "Billing marca COMPLETED solo después de la asignación idempotente de capacidad."
    note for LessonProgress "Avance individual del alumno (módulo Virtual) guardando marcas de tiempo de video."
    note for PhysicalCourse "Gestión presencial (módulo Physical) con control de aforo y profesor asignado."
    note for CapacityHold "Retención interna breve; no es una reserva visible ni accionable por el alumno."
    note for Attendance "Control de acceso real (módulo Physical) mediante escaneo de código QR."

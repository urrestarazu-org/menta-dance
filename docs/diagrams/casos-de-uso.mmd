---
title: Diagrama de Casos de Uso - Menta Dance
---
flowchart LR
    %% Actores Humanos
    subgraph Actores ["👥 Actores del Sistema"]
        direction TB
        alumno["👤 Alumno<br/>(Virtual / Presencial)"]
        profesor["👨‍🏫 Profesor"]
        recep["💁 Recepcionista"]
        admin["👤 Administrador"]
    end

    %% Frontera del Sistema
    subgraph Sistema ["🎓 Menta Dance"]
        direction TB

        %% Gestión de Cuentas y Seguridad
        subgraph Sec ["Seguridad y Accesos"]
            uc_register(["Registrar Cuenta"])
            uc_activate(["Activar Cuenta con Código"])
            uc_login(["Iniciar Sesión"])
            uc_reset_pass(["Recuperar Contraseña"])
            uc_lock_user(["Bloquear Cuenta por Seguridad"])
        end

        %% Contenido y Cursos
        subgraph Contenido ["Academia Virtual"]
            uc_catalog(["Ver Catálogo de Cursos"])
            uc_preview(["Ver Clases de Prueba (Preview)"])
            uc_stream(["Ver Lección / Streaming Video"])
            uc_progress(["Registrar Progreso de Lección"])
            uc_manage_content(["Gestionar Cursos, Módulos y Lecciones"])
        end

        %% Suscripciones y Pagos
        subgraph Pagos ["Suscripciones y Facturación"]
            uc_subscribe(["Suscribirse a Plan / Combo"])
            uc_quote_physical(["Cotizar Mensualidad / Sesión Individual"])
            uc_buy_physical(["Comprar y Recibir Cupo Automáticamente"])
            uc_pay_mp(["Realizar Pago Online (Mercado Pago)"])
            uc_pay_manual(["Subir Comprobante Pago Manual"])
            uc_verify_pay(["Verificar y Aprobar Pagos (MP/Manual)"])
            uc_audit_prices(["Auditar Historial de Precios"])
            uc_history(["Ver Historial de Pagos Personal"])
            uc_define_price(["Definir Precio Mensual y Recargo Individual"])
        end

        %% Academia Física e IoT
        subgraph Asistencia ["Academia Presencial"]
            uc_view_sessions(["Consultar Sesiones y Cupos"])
            uc_assign_capacity(["Asignar Cupo tras Pago"])
            uc_qr_gen(["Generar QR Temporal de Acceso"])
            uc_qr_scan(["Escanear QR (Check-in Automático)"])
            uc_manual_checkin(["Registrar Check-in Manual"])
            uc_correct_attend(["Corregir Registro de Asistencia"])
        end
    end

    %% Sistemas Externos
    subgraph Externos ["🌐 Sistemas Externos"]
        sys_mp["💳 Mercado Pago"]
        sys_qr["📟 Lector QR IoT"]
        sys_mail["📧 Servidor SMTP"]
    end

    %% Relaciones Alumno
    alumno --> uc_register
    alumno --> uc_activate
    alumno --> uc_login
    alumno --> uc_reset_pass
    alumno --> uc_catalog
    alumno --> uc_preview
    alumno --> uc_stream
    alumno --> uc_progress
    alumno --> uc_subscribe
    alumno --> uc_quote_physical
    alumno --> uc_buy_physical
    alumno --> uc_view_sessions
    alumno --> uc_pay_mp
    alumno --> uc_pay_manual
    alumno --> uc_history
    alumno --> uc_qr_gen

    %% Relaciones Profesor
    profesor --> uc_login
    profesor --> uc_catalog
    profesor --> uc_stream
    profesor --> uc_manage_content
    profesor --> uc_define_price

    %% Relaciones Recepcionista
    recep --> uc_login
    recep --> uc_manual_checkin
    recep --> uc_correct_attend

    %% Relaciones Administrador
    admin --> uc_login
    admin --> uc_manage_content
    admin --> uc_verify_pay
    admin --> uc_audit_prices
    admin --> uc_lock_user
    admin --> uc_manual_checkin
    admin --> uc_correct_attend

    %% Relaciones con Sistemas Externos
    uc_activate --> sys_mail
    uc_reset_pass --> sys_mail
    uc_pay_mp --> sys_mp
    uc_verify_pay --> sys_mp
    sys_qr --> uc_qr_scan
    uc_qr_gen -.-> |"incluye"| uc_qr_scan

    %% Relaciones internas de Casos de Uso
    uc_register -.-> |"incluye"| uc_activate
    uc_subscribe -.-> |"extiende"| uc_pay_mp
    uc_subscribe -.-> |"extiende"| uc_pay_manual
    uc_buy_physical -.-> |"incluye"| uc_quote_physical
    uc_buy_physical -.-> |"incluye"| uc_assign_capacity
    uc_stream -.-> |"incluye"| uc_progress

    %% Estilos de Nodos
    style alumno fill:#2d9cdb,stroke:#1a7ab8,color:#fff
    style profesor fill:#2d9cdb,stroke:#1a7ab8,color:#fff
    style recep fill:#2d9cdb,stroke:#1a7ab8,color:#fff
    style admin fill:#2d9cdb,stroke:#1a7ab8,color:#fff
    
    style sys_mp fill:#ff6b35,stroke:#cc5529,color:#fff
    style sys_qr fill:#ff6b35,stroke:#cc5529,color:#fff
    style sys_mail fill:#ff6b35,stroke:#cc5529,color:#fff
